# Balena deploy settings
TZ=Asia/Tokyo

# MariaDB / Zabbix
MARIADB_PASSWORD=change-me
MARIADB_ROOT_PASSWORD=change-root-password
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-password

# Grafana
GF_SECURITY_ADMIN_PASSWORD=change-grafana-password

# Cloudflare Tunnel
CF_TUNNEL_TOKEN=

# USB storage helper
USB_LABEL=PI4DATA
USB_CHECK_INTERVAL=30

# MariaDB backup rotation on USB
BACKUP_INTERVAL_SEC=21600
BACKUP_RETENTION_COUNT=14
BACKUP_MAX_USAGE_PERCENT=85
