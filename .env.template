# Balena deploy settings
TZ=Asia/Tokyo

# MariaDB / Zabbix
DB_NAME=zabbix
DB_USER=zabbix
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-root-password

# Zabbix tuning
ZBX_STARTPOLLERS=10
ZBX_STARTPINGERS=4
ZBX_CACHE_SIZE=128M
ZBX_HISTORYCACHESIZE=32M
ZBX_TRENDCACHESIZE=32M
ZBX_VALUECACHESIZE=64M

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-grafana-password
GRAFANA_PLUGINS=

# Cloudflare Tunnel
CF_TUNNEL_TOKEN=

# USB storage helper
USB_LABEL=PI4DATA
USB_CHECK_INTERVAL=30

# MariaDB backup rotation on USB
BACKUP_INTERVAL_SEC=21600
BACKUP_RETENTION_COUNT=14
BACKUP_MAX_USAGE_PERCENT=85
